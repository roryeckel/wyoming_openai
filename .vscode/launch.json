    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Wyoming OpenAI",
            "type": "debugpy",
            "request": "launch",
            "module": "wyoming_openai",
            "console": "integratedTerminal",
            "args": [
                "--log-level", "debug"
            ],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
